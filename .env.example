APP_NAME="APP CAMPANHAS EVENTOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/

# URLs
DOMAIN_HOME=https://home.seudominio-principal.com.br
DOMAIN_PAINEL=https://painel.seudominio-principal.com.br
DOMAIN_EVENTOS=https://eventos.seudominio-principal.com.br
DOMAIN_CAMPANHAS=https://campanhas.seudominio-principal.com.br
DOMAIN_ASSINATURAS=https://assinaturas.seudominio-principal.com.br

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=ingrosseai_bd
DB_USERNAME=proeventpay_user
DB_PASSWORD=123456

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database
# QUEUE_FAILED_DRIVER=database
# QUEUE_FAILED_DRIVER=database-uuids

SESSION_DRIVER=database
SESSION_LIFETIME=120
# DEV
SESSION_DOMAIN=null
# PRD
# SESSION_DOMAIN=.seudominio-principal.com.br
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================================
# CONFIGURAÇÃO DE EMAIL OTIMIZADA - RESEND + SMTP FALLBACK
# ============================================================================

# OPÇÃO 1: Resend como principal com SMTP fallback (ALTAMENTE RECOMENDADO)
# ---------------------------------------------------------------------------
MAIL_MAILER=failover
# MAIL_MAILER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# Como obter o RESEND_API_KEY:
# 1. Acesse https://resend.com
# 2. Crie conta gratuita (3.000 emails/mês grátis)
# 3. Vá em "API Keys" no dashboard
# 4. Crie uma nova chave (começa com "re_")
# 5. Adicione o domínio em "Domains" (ex: seudominio-principal.com.br)

# OPÇÃO 2: Usar apenas SMTP tradicional (atual, com timeouts)
# ---------------------------------------------------------------------------
# MAIL_MAILER=smtp

# OPÇÃO 3: Usar apenas Resend (sem fallback)
# ---------------------------------------------------------------------------
# MAIL_MAILER=resend

# Configurações SMTP (Usadas como fallback ou principal)
MAIL_HOST=mail.seudominio-principal.com.br
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=noreply@seudominio-principal.com.br
MAIL_PASSWORD=XXXYYY123456

# Configurações básicas obrigatórias
MAIL_FROM_ADDRESS=noreply@seudominio-principal.com.br
MAIL_FROM_NAME="${APP_NAME}"
MAIL_BCC_NOREPLY=noreply@seudominio-principal.com.br
MAIL_BCC_PAGAMENTOS=pagamentos@seudominio-principal.com.br
MAIL_FALLBACK_BUYER=comprador.sememail@seudominio-principal.com.br

# Timeouts otimizados para SMTP
MAIL_TIMEOUT=30
MAIL_SSL_TIMEOUT=30
MAIL_EHLO_DOMAIN=seudominio-principal.com.br

# Rate limiting (emails por minuto)
# Resend: até 100/min, SMTP: 30/min recomendado
MAIL_RATE_LIMIT=100

# Log de emails (útil para debug)
MAIL_LOG_CHANNEL=stack

# ============================================================================
# BENEFÍCIOS DA CONFIGURAÇÃO RECOMENDADA (failover):
# ============================================================================
# ✅ 99%+ taxa de entrega (Resend)
# ✅ Velocidade alta (< 1 segundo)
# ✅ Zero timeouts SMTP
# ✅ Fallback automático SMTP se Resend falhar
# ✅ Analytics detalhados no Resend dashboard
# ✅ Domínio personalizado incluído
# ✅ Rate limit 100 emails/minuto vs 30 SMTP
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
