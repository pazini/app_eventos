{
    "listeners": {
        "*:80": {
            "pass": "applications/laravel"
        }
    },
    "applications": {
        "laravel": {
            "type": "php",
            "root": "/var/www/html/public",
            "script": "index.php",
            "user": "unit",
            "group": "unit",
            "options": {
                "file": "/usr/local/etc/php/php.ini",
                "admin": {
                    "memory_limit": "512M",
                    "upload_max_filesize": "64M",
                    "post_max_size": "64M"
                }
            }
        }
    }
}
